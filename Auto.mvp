"""
auto_clip_mvp.py
MVP pipeline:
- ingest (uploads + authorized sources)
- analyze (scene detect, audio peaks, transcript)
- generate clips (30-60s candidates)
- score & optionally approve
- post to YouTube (example)
"""

import os
import subprocess
import tempfile
import json
import time
from pathlib import Path
from typing import List, Dict, Any
import requests

# pip install pyscenedetect pydub ffmpeg-python openai-whisper google-api-python-client google-auth-oauthlib python-dotenv
import scenedetect
from scenedetect import VideoManager, SceneManager
from scenedetect.detectors import ContentDetector
from pydub import AudioSegment, silence
import whisper

# ---------- CONFIG ----------
ROOT = Path("clips_work")
ROOT.mkdir(exist_ok=True)
MODEL = whisper.load_model("small")  # or "base" for speed
CATEGORIES = {
    "anime": {"sources": ["https://example.com/anime-rss"], "keywords": ["anime", "manga"]},
    "dancing": {"sources": ["https://example.com/dance-rss"], "keywords": ["dance", "dancing", "choreography"]},
    "reality": {"sources": ["https://example.com/reality-rss"], "keywords": ["reality", "clip"]},
    "funny": {"sources": ["https://example.com/funny-rss"], "keywords": ["funny", "comedy"]},
    "tv": {"sources": ["https://example.com/tv-rss"], "keywords": ["tv", "episode", "clip"]},
}
# Authorized sources list (YouTube channel IDs, RSS feeds, partner upload endpoints)
AUTHORIZED_SOURCES = {
    "youtube_channels": ["UC_x5XG1OV2P6uZZ5FSM9Ttw"],  # example
    "rss_feeds": [],
    "partner_upload_api": []  # endpoints where creators push content with consent
}
# YouTube upload config (requires OAuth client_secrets.json)
YOUTUBE_CLIENT_SECRETS = "client_secrets.json"
YOUTUBE_CREDENTIALS = "youtube_credentials.json"

# Clip settings
MIN_CLIP_SEC = 20
MAX_CLIP_SEC = 60
TARGET_PLATFORMS = ["youtube"]  # extend with 'tiktok','instagram' later

# ---------- UTILITIES ----------
def run_cmd(cmd: List[str]):
    print("RUN:", " ".join(cmd))
    subprocess.check_call(cmd)

def ffmpeg_trim(input_path: str, start: float, duration: float, out_path: str):
    cmd = [
        "ffmpeg", "-y", "-i", input_path,
        "-ss", str(start), "-t", str(duration),
        "-c:v", "libx264", "-preset", "fast", "-crf", "23",
        "-c:a", "aac", "-b:a", "128k",
        out_path
    ]
    run_cmd(cmd)

def ffmpeg_resize_and_burn_captions(input_path: str, out_path: str, width: int, height: int, captions_path: str = None):
    # simple resize and burn captions if provided (assumes .srt)
    vf = f"scale={width}:{height}:force_original_aspect_ratio=decrease,pad={width}:{height}:(ow-iw)/2:(oh-ih)/2"
    cmd = ["ffmpeg", "-y", "-i", input_path]
    if captions_path:
        cmd += ["-vf", f"{vf},subtitles={captions_path}"]
    else:
        cmd += ["-vf", vf]
    cmd += ["-c:v", "libx264", "-preset", "fast", "-crf", "23", "-c:a", "aac", "-b:a", "128k", out_path]
    run_cmd(cmd)

# ---------- ANALYSIS ----------
def detect_scenes(video_path: str) -> List[Dict[str, float]]:
    video_manager = VideoManager([video_path])
    scene_manager = SceneManager()
    scene_manager.add_detector(ContentDetector(threshold=30.0))
    base_timecode = video_manager.get_base_timecode()
    video_manager.start()
    scene_manager.detect_scenes(frame_source=video_manager)
    scene_list = scene_manager.get_scene_list(base_timecode)
    video_manager.release()
    scenes = []
    for start, end in scene_list:
        scenes.append({"start": start.get_seconds(), "end": end.get_seconds()})
    return scenes

def find_audio_peaks(video_path: str, min_silence_len=300, silence_thresh=-40):
    # extract audio to temp file
    tmp = tempfile.NamedTemporaryFile(suffix=".wav", delete=False)
    tmp.close()
    run_cmd(["ffmpeg", "-y", "-i", video_path, "-vn", "-acodec", "pcm_s16le", "-ar", "16000", "-ac", "1", tmp.name])
    audio = AudioSegment.from_wav(tmp.name)
    # find non-silent chunks (in ms)
    nonsilent = silence.detect_nonsilent(audio, min_silence_len=min_silence_len, silence_thresh=silence_thresh)
    peaks = []
    for start_ms, end_ms in nonsilent:
        start_s = start_ms / 1000.0
        end_s = end_ms / 1000.0
        peaks.append({"start": start_s, "end": end_s})
    os.unlink(tmp.name)
    return peaks

def transcribe(video_path: str) -> Dict[str, Any]:
    # Whisper returns segments with timestamps
    result = MODEL.transcribe(video_path)
    return result

# ---------- CLIP GENERATION ----------
def generate_candidate_clips(video_path: str) -> List[Dict[str, Any]]:
    scenes = detect_scenes(video_path)
    peaks = find_audio_peaks(video_path)
    # combine heuristics: choose scene centers and audio peaks
    candidates = []
    for s in scenes:
        dur = s["end"] - s["start"]
        if dur < 2: 
            continue
        center = s["start"] + dur/2
        start = max(0, center - MIN_CLIP_SEC/2)
        duration = min(MAX_CLIP_SEC, dur, MAX_CLIP_SEC)
        candidates.append({"start": start, "duration": duration, "reason": "scene_center"})
    for p in peaks:
        dur = p["end"] - p["start"]
        start = max(0, p["start"] - 2)
        duration = min(MAX_CLIP_SEC, max(MIN_CLIP_SEC, dur + 4))
        candidates.append({"start": start, "duration": duration, "reason": "audio_peak"})
    # dedupe by overlap and sort by duration desc
    candidates = sorted(candidates, key=lambda x: x["duration"], reverse=True)
    final = []
    used_ranges = []
    for c in candidates:
        s = c["start"]; e = s + c["duration"]
        overlap = any(not (e <= ur[0] or s >= ur[1]) for ur in used_ranges)
        if not overlap:
            final.append(c)
            used_ranges.append((s, e))
        if len(final) >= 8:
            break
    return final

def make_srt_from_transcript(transcript: Dict[str, Any], out_path: str):
    # simple SRT writer from whisper segments
    with open(out_path, "w", encoding="utf-8") as f:
        for i, seg in enumerate(transcript.get("segments", []), start=1):
            start = seg["start"]
            end = seg["end"]
            def fmt(t):
                h = int(t//3600); m = int((t%3600)//60); s = int(t%60); ms = int((t - int(t))*1000)
                return f"{h:02d}:{m:02d}:{s:02d},{ms:03d}"
            f.write(f"{i}\n{fmt(start)} --> {fmt(end)}\n{seg['text'].strip()}\n\n")

# ---------- SOURCE INGESTION (AUTHORIZED) ----------
def download_youtube_video(video_id: str, out_dir: str) -> str:
    # Use yt-dlp externally (must be installed). This is an example; ensure you have rights.
    out_path = os.path.join(out_dir, f"{video_id}.mp4")
    cmd = ["yt-dlp", "-f", "bestvideo+bestaudio", "--merge-output-format", "mp4", "-o", out_path, f"https://www.youtube.com/watch?v={video_id}"]
    run_cmd(cmd)
    return out_path

def scan_youtube_channel_for_recent(channel_id: str, api_key: str, max_results=5) -> List[str]:
    # returns video IDs (requires YouTube Data API key)
    url = "https://www.googleapis.com/youtube/v3/search"
    params = {"part": "id", "channelId": channel_id, "order": "date", "maxResults": max_results, "key": api_key}
    r = requests.get(url, params=params)
    r.raise_for_status()
    items = r.json().get("items", [])
    vids = [it["id"]["videoId"] for it in items if it["id"].get("videoId")]
    return vids

# ---------- SIMPLE SCORING ----------
def score_clip(candidate: Dict[str, Any], transcript: Dict[str, Any]) -> float:
    # naive scoring: prefer speech presence and length
    score = 0.0
    score += candidate["duration"] / MAX_CLIP_SEC
    # speech density
    words = sum(len(seg["text"].split()) for seg in transcript.get("segments", []))
    if words > 0:
        score += min(1.0, words / 50.0)
    return score

# ---------- POSTING (YouTube example) ----------
def youtube_upload(video_file: str, title: str, description: str, tags: List[str], privacy="public"):
    # Minimal example using googleapiclient; requires OAuth flow and credentials
    from googleapiclient.discovery import build
    from googleapiclient.http import MediaFileUpload
    from google_auth_oauthlib.flow import InstalledAppFlow
    from google.auth.transport.requests import Request
    import pickle

    SCOPES = ["https://www.googleapis.com/auth/youtube.upload"]
    creds = None
    if os.path.exists(YOUTUBE_CREDENTIALS):
        with open(YOUTUBE_CREDENTIALS, "rb") as f:
            creds = pickle.load(f)
    if not creds or not creds.valid:
        if creds and creds.expired and creds.refresh_token:
            creds.refresh(Request())
        else:
            flow = InstalledAppFlow.from_client_secrets_file(YOUTUBE_CLIENT_SECRETS, SCOPES)
            creds = flow.run_console()
        with open(YOUTUBE_CREDENTIALS, "wb") as f:
            pickle.dump(creds, f)
    youtube = build("youtube", "v3", credentials=creds)
    body = {"snippet": {"title": title, "description": description, "tags": tags}, "status": {"privacyStatus": privacy}}
    media = MediaFileUpload(video_file, chunksize=-1, resumable=True)
    req = youtube.videos().insert(part="snippet,status", body=body, media_body=media)
    resp = None
    while resp is None:
        status, resp = req.next_chunk()
        if status:
            print(f"Upload progress: {int(status.progress() * 100)}%")
    print("Upload complete, video id:", resp["id"])
    return resp["id"]

# ---------- MAIN WORKFLOW ----------
def process_video_file(video_path: str, category: str, auto_post: bool = False, api_keys: Dict[str, str] = {}):
    print("Processing:", video_path, "category:", category)
    workdir = ROOT / Path(video_path).stem
    workdir.mkdir(parents=True, exist_ok=True)
    # 1) transcript
    transcript = transcribe(video_path)
    srt_path = str(workdir / "captions.srt")
    make_srt_from_transcript(transcript, srt_path)
    # 2) generate candidates
    candidates = generate_candidate_clips(video_path)
    results = []
    for i, c in enumerate(candidates):
        out_clip = str(workdir / f"clip_{i}.mp4")
        ffmpeg_trim(video_path, c["start"], c["duration"], out_clip)
        # resize for vertical
        out_clip_v = str(workdir / f"clip_{i}_9x16.mp4")
        ffmpeg_resize_and_burn_captions(out_clip, out_clip_v, 1080, 1920, srt_path)
        # score
        score = score_clip(c, transcript)
        results.append({"clip": out_clip_v, "score": score, "meta": c})
    # sort by score
    results = sorted(results, key=lambda x: x["score"], reverse=True)
    # auto-post top clip if allowed
    if auto_post and results:
        top = results[0]
        title = f"[{category}] AutoClip {int(time.time())}"
        desc = "Auto-generated clip"
        tags = [category, "autoclip"]
        if "youtube" in TARGET_PLATFORMS:
            vid = youtube_upload(top["clip"], title, desc, tags)
            print("Posted to YouTube:", vid)
    return results

# ---------- SCAN SOURCES (authorized) ----------
def scan_and_ingest(api_keys: Dict[str, str], categories: List[str]):
    # Example: scan configured YouTube channels for each category
    for cat in categories:
        cfg = CATEGORIES.get(cat, {})
        # for demo, use AUTHORIZED_SOURCES youtube channels
        for ch in AUTHORIZED_SOURCES.get("youtube_channels", []):
            vids = scan_youtube_channel_for_recent(ch, api_keys.get("youtube_api_key", ""), max_results=3)
            for vid in vids:
                # NOTE: ensure you have rights before downloading
                print("Found video", vid, "for category", cat)
                local = download_youtube_video(vid, str(ROOT))
                process_video_file(local, cat, auto_post=False, api_keys=api_keys)

# ---------- RUN EXAMPLE ----------
if __name__ == "__main__":
    # Example usage: process a local file
    # python auto_clip_mvp.py /path/to/video.mp4 dancing
    import sys
    if len(sys.argv) >= 3:
        path = sys.argv[1]
        cat = sys.argv[2]
        process_video_file(path, cat, auto_post=False, api_keys={})
    else:
        print("Usage: python auto_clip_mvp.py /path/to/video.mp4 category")
